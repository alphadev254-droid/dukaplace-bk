generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String    @id @default(uuid())
  name                 String
  email                String    @unique(map: "email")
  password             String
  phone                String?
  avatar               String?
  role                 Role      @default(buyer)
  location             String?
  isVerified           Boolean   @default(false) @map("is_verified")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  isActive             Boolean   @default(true) @map("is_active")
  passwordResetToken   String?   @map("password_reset_token")
  passwordResetExpires DateTime? @map("password_reset_expires")
  products             Product[]
  buyerOrders          Order[]        @relation("BuyerOrders")
  sellerOrders         Order[]        @relation("SellerOrders")
  wishlist             Wishlist[]
  buyerConversations   Conversation[] @relation("BuyerConversations")
  sellerConversations  Conversation[] @relation("SellerConversations")
  messages             Message[]

  @@map("users")
}

model Category {
  id           String    @id @default(uuid())
  name         String
  slug         String    @unique(map: "slug")
  icon         String?
  description  String?
  parentId     String?   @map("parent_id")
  productCount Int       @default(0) @map("product_count")
  createdAt    DateTime  @default(now()) @map("created_at")
  products     Product[]

  @@map("categories")
}

model Product {
  id          String           @id @default(uuid())
  title       String
  slug        String           @unique(map: "slug")
  description String?          @db.Text
  price       Decimal          @db.Decimal(10, 2)
  stock       Int              @default(1)
  currency    String           @default("KES")
  categoryId  String?          @map("category_id")
  sellerId    String           @map("seller_id")
  location    String?
  status      ProductStatus    @default(active)
  condition   ProductCondition @default(new) @map("product_condition")
  featured    Boolean          @default(false)
  views       Int              @default(0)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  category    Category?        @relation(fields: [categoryId], references: [id])
  seller      User             @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  images      ProductImage[]
  orders      Order[]
  wishlist    Wishlist[]
  conversations Conversation[]

  @@index([categoryId], map: "products_category_id_fkey")
  @@index([sellerId], map: "products_seller_id_fkey")
  @@map("products")
}

model ProductImage {
  id           String   @id @default(uuid())
  productId    String   @map("product_id")
  url          String
  alt          String?
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at")
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

model Order {
  id              String      @id @default(uuid())
  productId       String      @map("product_id")
  buyerId         String      @map("buyer_id")
  sellerId        String      @map("seller_id")
  amount          Decimal     @db.Decimal(10, 2)
  paymentMethod   String?     @map("payment_method")
  deliveryAddress String?     @map("delivery_address") @db.Text
  status          OrderStatus @default(pending)
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  product         Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  buyer           User        @relation("BuyerOrders",  fields: [buyerId],  references: [id], onDelete: Cascade)
  seller          User        @relation("SellerOrders", fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([buyerId])
  @@index([sellerId])
  @@index([productId])
  @@map("orders")
}

model Wishlist {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  productId String   @map("product_id")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId],    references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId], map: "unique_wishlist")
  @@map("wishlist")
}

model Conversation {
  id              String   @id @default(uuid())
  productId       String   @map("product_id")
  buyerId         String   @map("buyer_id")
  sellerId        String   @map("seller_id")
  lastMessage     String?  @map("last_message") @db.Text
  lastMessageTime DateTime @default(now()) @map("last_message_time")
  createdAt       DateTime @default(now()) @map("created_at")
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  buyer           User     @relation("BuyerConversations",  fields: [buyerId],  references: [id], onDelete: Cascade)
  seller          User     @relation("SellerConversations", fields: [sellerId], references: [id], onDelete: Cascade)
  messages        Message[]

  @@unique([productId, buyerId, sellerId], map: "unique_conversation")
  @@map("conversations")
}

model Message {
  id             String       @id @default(uuid())
  conversationId String       @map("conversation_id")
  senderId       String       @map("sender_id")
  message        String       @db.Text
  isRead         Boolean      @default(false) @map("is_read")
  createdAt      DateTime     @default(now()) @map("created_at")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId],       references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("messages")
}

model EmailQueue {
  id           String           @id @default(uuid())
  toEmail      String           @map("to_email")
  toName       String?          @map("to_name")
  subject      String
  template     String
  templateData String?          @map("template_data") @db.LongText
  attachments  String?          @db.LongText
  status       EmailQueueStatus @default(pending)
  attempts     Int              @default(0)
  maxAttempts  Int              @default(3) @map("max_attempts")
  errorMessage String?          @map("error_message") @db.Text
  scheduledAt  DateTime         @default(now()) @map("scheduled_at")
  sentAt       DateTime?        @map("sent_at")
  createdAt    DateTime         @default(now()) @map("created_at")

  @@map("email_queue")
}

enum Role {
  buyer
  seller
  admin
}

enum ProductStatus {
  active
  inactive
  sold
}

enum ProductCondition {
  new
  used
  refurbished
}

enum OrderStatus {
  pending
  confirmed
  shipped
  delivered
  cancelled
}

enum EmailQueueStatus {
  pending
  sent
  failed
}
